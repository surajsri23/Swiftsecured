# This .gitignore file is configured to exclude files and directories commonly generated 
# during Python development, virtual environments, IDE configurations, operating system 
# artifacts, project-specific files, and frontend build artifacts. It is also optimized 
# for deployment on Render.com.

# Python: Excludes compiled Python files, caches, and build artifacts.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project specific
*.csv
*.h5
*.model
.env
*.log

# Logs
*.log
logs/
log/

# Test and coverage
node_modules/
coverage/
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# Frontend
static/css/output.css
.cache/
dist/
coverage/
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Operating System
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp
*~
# Add the following line to ensure the SimpleModel class is available during unpickling
*pkl
